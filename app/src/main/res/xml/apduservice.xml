<?xml version="1.0" encoding="utf-8"?>
<!--
    HCE service AID registrations for the NFC Listener Mode Routing Table (LMRT).

    These entries are NOT used to gate or observe NFC polling frames. They are
    needed so that the NFC controller's LMRT has entries that route the listed
    AIDs to the Device Host (DH). Once routed to DH, our Xposed hook in
    LmrtHijackModule intercepts RegisteredAidCache.resolveAid() and delivers
    every AID to PassthroughHceService, which forwards it to the SE via OMAPI.

    Observer Mode (shouldDefaultToObserveMode) has been removed: the module no
    longer needs to detect polling frames before committing to a transaction.
    OMAPI is connected on demand when the user presses Start; every incoming
    AID SELECT is handled immediately.

    AID prefix coverage:
      A0 xx xx xx xx  -  ISO-registered application identifiers (payment, transit...)
      F0 xx xx xx xx  -  Proprietary application identifiers

    When an AID SELECT arrives for an AID NOT listed here, the NFC controller
    routes it according to its own default route (typically to the SE), so it
    never reaches the DH. To intercept more AIDs, add more prefix entries here.

    See:
      ref_aosp/NfcNci/src/com/android/nfc/cardemulation/AidRoutingManager.java
        - how this list populates the LMRT
      ref_aosp/NfcNci/src/com/android/nfc/cardemulation/RegisteredAidCache.java
        - resolveAid() which our hook overrides
-->
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/servicedesc"
    android:requireDeviceUnlock="true">

    <!-- AID prefixes routed to the Device Host.
         The SE ultimately decides per-AID whether to accept; ApduPassthroughController
         opens a logical channel and returns the SE's response verbatim. -->
    <aid-group android:description="@string/aiddescription" android:category="other">
        <!-- Payment networks -->
        <aid-filter android:name="A000000003*"/><!-- Visa -->
        <aid-filter android:name="A000000004*"/><!-- Mastercard / Maestro -->
        <aid-filter android:name="A000000025*"/><!-- American Express -->
        <aid-filter android:name="A000000029*"/><!-- American Express (alternate RID) -->
        <aid-filter android:name="A000000032*"/><!-- Visa Electron -->
        <aid-filter android:name="A000000045*"/><!-- Maestro (UK Domestic) -->
        <aid-filter android:name="A000000065*"/><!-- JCB -->
        <aid-filter android:name="A000000152*"/><!-- Discover / Diners Club -->
        <aid-filter android:name="A000000277*"/><!-- Interac -->
        <aid-filter android:name="A000000333*"/><!-- China UnionPay -->
        <aid-filter android:name="A000000632*"/><!-- eftpos Australia -->
        <aid-filter android:name="A000000658*"/><!-- MIR (Russia) -->
        <aid-filter android:name="A000000724*"/><!-- RuPay (India / NPCI) -->
        <aid-filter android:name="A000000006*"/><!-- Bancontact / Mister Cash -->
        <aid-filter android:name="A000000042*"/><!-- Carte Bancaire (CB) -->
        <aid-filter android:name="A000000172*"/><!-- Girocard (Germany) -->
        <!-- Transit / transport -->
        <aid-filter android:name="A000000031*"/><!-- Visa Transit -->
        <aid-filter android:name="A000000046*"/><!-- Visa Transit (alternate) -->
        <!-- Proprietary F0 range -->
        <aid-filter android:name="F000000000*"/><!-- Proprietary (F0 00 00 00 00) -->
        <aid-filter android:name="F000000001*"/><!-- Proprietary (F0 00 00 00 01) -->
        <aid-filter android:name="F000000002*"/><!-- Proprietary (F0 00 00 00 02) -->
        <aid-filter android:name="F000000003*"/><!-- Proprietary (F0 00 00 00 03) -->
    </aid-group>
</host-apdu-service>
