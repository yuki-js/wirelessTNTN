<?xml version="1.0" encoding="utf-8"?>
<!--
    AIDs are registered dynamically at runtime via CardEmulation.registerAidsForService()
    based on the list entered by the user in the UI.  No static AID filters are declared here.
    Observer Mode is not used.
-->
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/servicedesc"
    android:requireDeviceUnlock="true">

    <!-- Placeholder aid-group required by the schema; actual AIDs are registered at runtime. -->
    <aid-group android:description="@string/aiddescription" android:category="other" />
</host-apdu-service>
